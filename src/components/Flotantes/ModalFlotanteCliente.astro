<div id="modalCliente" class="modal">
    <div class="modal-card">
        <header class="modal-header">
            <h3>Actualizar datos de Cliente</h3>
            <button id="btnCerrarModalClient" class="close-btn">X</button>
        </header>

        <div class="model-body">
            <div class="field field-compact">
                <span><strong>Id Cliente:</strong><span id="modalClienteId" data-id=""></span></span>
                <span><strong>Fecha creacion:</strong><span id="modalClienteFecha"></span></span>
                <span><strong>Correo:</strong><span id="modalClienteCorreo"></span></span>
            </div>

            <div class="field">
                <label>Nombre:</label>
                <input id="modalActualizarClienteNombre" type="text">
            </div>

            <div>
                <label>Telefono:</label>
                <input id="modalActualizarClienteTelefono" type="text">
            </div>

            <div class="field">
                <label>Tipo:</label>
                <select id="modalActualizarClienteTipo">
                    <option value="NORMAL">Normal</option>
                    <option value="DEUDOR">Deudor</option>
                </select>
            </div>

            <div class="field">
                <label>Estado:</label>
                <select id="modalActualizarClienteEstado">
                    <option value="true">Activo</option>
                    <option value="false">Inactivo</option>
                </select>
            </div>


        </div>

        <footer class="modal-footer">
            <button id="btnLimpiarCamposClientes" class="btn-danger">LIMPIAR CAMPOS</button>
            <div class="footer-actions">
                <button id="btnGuardaCambiosClientes" class="btn-primary">GUARDAR CAMBIOS</button>
            </div>
        </footer>


    </div>
</div>


<style>
.modal-info {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 20px;
  background: #f9fafb;
  font-size: 12px;
  color: #374151;
  border-top: 1px solid #e5e7eb;
  box-sizing: border-box;
}


.modal {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.55);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.field-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 12px;
}

.modal-card {
  background: #ffffff;
  width: min(540px, 92vw);
  border-radius: 10px;
  box-shadow: 0 20px 40px rgba(0,0,0,.2);
  overflow: visible;
  animation: fadeIn .2s ease-out;
}

/* Header */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 18px;
  border-bottom: 1px solid #e5e7eb;
}

.modal-header h3 {
  margin: 0;
  font-size: 18px;
}

.close-btn {
  background: none;
  border: none;
  font-size: 18px;
  cursor: pointer;
  opacity: .6;
}
.close-btn:hover {
  opacity: 1;
}
.field textarea {
  width: 100%;
  resize: vertical;
  min-height: 70px;
  padding: 8px 10px;
  box-sizing: border-box;
  border: 1px solid #d1d5db;
  border-radius: 8px;
  font-size: 13px;
}

*, *::before, *::after {
  box-sizing: border-box;
}

/* Body */
.modal-body {
  padding: 20px;
  display: grid;
  gap: 12px;
}

.field {
  display: flex;
  flex-direction: column;
}

.field label {
  font-size: 12px;
  color: #6b7280;
  margin-bottom: 4px;
}

.field input,
.field select {
  padding: 8px 10px;
  border: 1px solid #d1d5db;
  border-radius: 8px;
  font-size: 13px;
}

.field input:disabled {
  background: #f3f4f6;
  color: #6b7280;
}

/* Footer */
.modal-footer {
  padding: 12px 20px;
  border-top: 1px solid #e5e7eb;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-actions {
  display: flex;
  gap: 10px;
}

/* Buttons */
button {
  padding: 10px 10px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  font-size: 14px;
}

.btn-primary {
  background: #2563eb;
  color: white;
}
.btn-primary:hover {
  background: #1d4ed8;
}

.btn-secondary {
  background: #e5e7eb;
}

.btn-danger {
  background: #dc2626;
  color: white;
}



/* Animation */
@keyframes fadeIn {
  from {
    transform: translateY(10px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@media (max-width: 600px) {
  .modal-body {
    grid-template-columns: 1fr;
  }
}

</style>


<script>

  const modalCli = document.getElementById('modalCliente');
  if(modalCli && modalCli.dataset.bound !== 'true'){
    modalCli.dataset.bound = 'true';

    const $ = (selector) => modalCli.querySelector(selector);

    const nombre = $('#modalActualizarClienteNombre');
    const telefono = $('#modalActualizarClienteTelefono');
    const tipo = $('#modalActualizarClienteTipo');
    const estado = $('#modalActualizarClienteEstado');

    const idCliente = $('#modalClienteId');
    const fechaCreacion = $('#modalClienteFecha');
    const correoCliente = $('#modalClienteCorreo');
   

    const btnGuardar = $('#btnGuardaCambiosClientes');
    const btnCerrar = $('#btnCerrarModalClient');
    const btnLimpiar = $('#btnLimpiarCamposClientes');

    let currentClienteId = null;

    function cerrarModal(){
      modalCli.style.display= 'none';
    };

    function limpiarModal(){
      nombre.value = '';
      telefono.value = '';
      tipo.value = 'Normal';
      estado.value = 'true';

      idCliente.textContent = '';
      idCliente.dataset.id = '';

      fechaCreacion.textContent = '';
      correoCliente.textContent = '';
    };

    btnCerrar?.addEventListener('click', cerrarModal);

    btnLimpiar?.addEventListener('click', limpiarModal);

    btnGuardar?.addEventListener('click', (e) =>{
      e.preventDefault();

      const id = idCliente.dataset.id;

      if(!id){
        alert('ID de cliente no encontrado');
        return;
      }

      const data = {
        nombre: nombre.value,
        telefono: telefono.value,
        tipo: tipo.value,
        estado: estado.value === 'true'
      };

      modalCli.dispatchEvent(new CustomEvent('cliente:save',{
        detail: {
          id: Number(id),
          data
        },
        bubbles: true
      }));
    });


    document.addEventListener('keydown', (e) =>{
      if(e.key === 'Escape' && modalCli.style.display === 'flex'){
        cerrarModal();
      }
    });

    modalCli.addEventListener('click', (e) => {
      if (e.target === modalCli) cerrarModal();
    });

    window.modalCliente = {
      abrir(cliente){
        //
        limpiarModal();

        currentClienteId = cliente.id_cliente;
        //idCliente.textContent = 'Cargando...';
        
        idCliente.dataset.id = cliente.id_cliente;
        idCliente.textContent = cliente.id_cliente;

        nombre.value = cliente.nombre;
        telefono.value = cliente.telefono;
        tipo.value = cliente.tipo;
        estado.value = String(cliente.estado);

        fechaCreacion.textContent = cliente.fecha_creacion;
        correoCliente.textContent = cliente.email;

        modalCli.style.display = 'flex';

      },
      cerrarModal
    };
  }
</script>


